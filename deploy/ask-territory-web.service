# systemd unit for the Ask Territory web app (non-Docker install).
# Install:  sudo cp deploy/ask-territory-web.service /etc/systemd/system/
#           sudo systemctl enable --now ask-territory-web
[Unit]
Description=Ask Territory web app
After=network-online.target ollama.service
Wants=network-online.target

[Service]
Type=simple
User=appuser
WorkingDirectory=/opt/ask-territory
Environment=PORT=8000
Environment=OLLAMA_HOST=http://127.0.0.1:11434
Environment=MODEL=qwen2.5:7b-instruct
ExecStart=/usr/bin/python3 -m webapp.server
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
