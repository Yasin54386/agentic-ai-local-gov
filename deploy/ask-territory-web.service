# systemd unit for the Ask Territory web app (non-Docker install).
# Install:  sudo cp deploy/ask-territory-web.service /etc/systemd/system/
#           sudo systemctl enable --now ask-territory-web
[Unit]
Description=Ask Territory web app
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=appuser
WorkingDirectory=/opt/ask-territory
Environment=PORT=8000
Environment=MODEL=claude-haiku-4-5
Environment=MAX_OUTPUT_TOKENS=500
Environment=BUDGET_MONTHLY_AUD=100
# Supply the API key out-of-band (do NOT commit it):
#   sudo systemctl edit ask-territory-web
#   [Service]
#   Environment=ANTHROPIC_API_KEY=sk-...
ExecStart=/usr/bin/python3 -m webapp.server
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
