# Copy to .env and edit. Used by docker-compose and the deploy scripts.

# Your domain (the one you bought). Set your real TLD here.
DOMAIN=ask-territory.com.au

# Email for Let's Encrypt / certbot TLS certificates.
LETSENCRYPT_EMAIL=arafat102875@gmail.com

# --- LLM backend (sovereign by default) -------------------------------------
# local  = self-hosted Ollama, no data leaves your network (DEFAULT, recommended)
# openai = a single OpenAI-compatible endpoint (self-hosted vLLM, or a hosted
#          provider). ⚠ sends prompts to that endpoint — only use with proper
#          no-training data terms. There is no multi-provider free-tier ensemble.
LLM_BACKEND=local

# Model name for the chosen backend.
#   local : qwen2.5:7b-instruct (good default) · qwen2.5:3b-instruct (lighter) ·
#           qwen2.5:32b-instruct (sharper, needs a GPU)
#   openai: e.g. gpt-4o-mini, or your vLLM model id
MODEL=qwen2.5:7b-instruct

# Only used when LLM_BACKEND=openai:
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# LLM_FALLBACK=0      # 1 = fall back to the other backend on failure

# --- Security ----------------------------------------------------------------
# Admin dashboard key. Empty = allow in dev. Set to a long random string in prod.
# Access: /admin?key=YOUR_KEY
ADMIN_KEY=

# Scrape trigger key. Empty = allow in dev. Set in prod to restrict POST /api/*/scrape.
SCRAPE_KEY=

# --- Rate limiting -----------------------------------------------------------
# Max requests per IP per window (default: 60 per 60 seconds).
RATE_LIMIT=60
RATE_WINDOW=60
